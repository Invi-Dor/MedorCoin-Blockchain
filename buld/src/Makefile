	cd /workspaces/MedorCoin-Blockchain/buld && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/MedorCore.dir/build.make src/CMakeFiles/MedorCore.dir/wallet.cpp.s
.PHONY : wallet.cpp.s

