{
  "name": "medorcoin-node",
  "version": "1.0.0",
  "description": "MedorCoin Blockchain Node - Sovereign Edition",
  "main": "server.cjs",
  "type": "module",
  "scripts": {
    "infra": "lsof -i :6379 -sTCP:LISTEN -t >/dev/null && echo 'Infrastructure already active' || bash setup-cluster.sh",
    "start": "node server.cjs",
    "dev": "npm run infra && npm start",
    "mine": "MINE=true node server.cjs",
    "test": "node log_test.js",
    "build": "node-gyp rebuild",
    "build:debug": "node-gyp rebuild --debug",
    "test:asan": "node-gyp rebuild --build-type=CI_ASAN && node server.cjs",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.3",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bs58check": "^4.0.0",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "level": "^8.0.0",
    "lodash": "^4.17.23",
    "msgpack5": "^6.0.2",
    "nodemailer": "^8.0.4",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redlock": "^5.0.0-beta.2",
    "secp256k1": "^5.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.7",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@types/node": "^22.19.15",
    "ethers": "^6.16.0",
    "hardhat": "^3.3.0",
    "typescript": "~5.8.0",
    "viem": "^2.47.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "Invi-Dor"
}
