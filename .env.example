# ══════════════════════════════════════════════════════════════════════════════
# MedorCoin API — Environment Configuration Template
#
# Copy this file to .env before starting the server:
#   cp .env.example .env
#
# Populate every value marked <REQUIRED> before deployment.
# Never commit the populated .env to version control.
# Ensure .env is listed in .gitignore.
#
# Generate secure random values with:
#   openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════

# ── API Server ────────────────────────────────────────────────────────────────
# Bind address must remain 127.0.0.1 in production. TLS termination is
# handled upstream by Nginx. Exposing this port directly to the internet
# bypasses TLS and all security headers.
MEDOR_API_BIND=127.0.0.1
MEDOR_API_PORT=18080
MEDOR_API_THREADS=8

# Maximum request body size in bytes (64 KB default)
MEDOR_API_MAX_REQUEST_BYTES=65536

# Maximum length of any single query parameter or JSON string field
MEDOR_API_MAX_PARAM_LENGTH=512

# Graceful shutdown timeout — milliseconds to wait for in-flight requests
# to complete before forcing exit
MEDOR_API_SHUTDOWN_TIMEOUT_MS=10000

# ── Admin Key ─────────────────────────────────────────────────────────────────
# Used exclusively for the key-issuance and key-revocation admin endpoints.
# This is separate from client API keys and must be kept strictly confidential.
# The value below is the live admin key for this deployment.
# Rotate it immediately if it is ever exposed.
MEDOR_ADMIN_KEY=be0a35b59bb1c4a133dcd17b5e56b77c5a07b 4372d96c2ae04282eeb1f6eb443

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Sustained requests permitted per second per API key
MEDOR_RATE_LIMIT_RPS=30

# Maximum burst allowance — tokens that can accumulate while a client is idle
MEDOR_RATE_LIMIT_BURST=60

# Milliseconds before an idle rate-limit bucket is eligible for eviction
MEDOR_RATE_LIMIT_IDLE_TIMEOUT_MS=60000

# ── Data Paths ────────────────────────────────────────────────────────────────
# All paths are relative to the working directory of the server process.
# Ensure the process user has read and write access to each directory.
# RocksDB creates the directories automatically if they do not exist.
MEDOR_RECEIPT_DB=data/receipts
MEDOR_RECEIPT_BACKUP=data/receipts_backup
MEDOR_KEY_DB=data/api_keys
MEDOR_KEY_BACKUP=data/api_keys_backup

# ── Receipt Storage ───────────────────────────────────────────────────────────
# Schema version — increment when the receipt JSON structure changes
MEDOR_RECEIPT_SCHEMA_VERSION=1

# Sync every individual write to disk before returning. Recommended for
# production; set to false only on high-throughput benchmarking rigs.
MEDOR_RECEIPT_SYNC_WRITES=true

# Run a full checksum-validated key scan when the receipt store opens
MEDOR_RECEIPT_VERIFY_ON_OPEN=false

# Attempt to restore from backup if the receipt DB fails to open
MEDOR_RECEIPT_RECOVER_FROM_BACKUP=false

# Trigger an automatic backup after this many writes (0 = backup on close only)
MEDOR_RECEIPT_BACKUP_AFTER_N_WRITES=0

# ── API Key Management ────────────────────────────────────────────────────────
# Default TTL in seconds for newly issued client keys when the caller does
# not specify an expiry (0 = keys never expire by default)
MEDOR_KEY_DEFAULT_TTL_SECONDS=0

# Trigger an automatic key-DB backup after this many writes (0 = on close only)
MEDOR_KEY_BACKUP_AFTER_N_WRITES=0

# isHealthy() probe retry count and inter-attempt delay
MEDOR_KEY_HEALTH_RETRIES=2
MEDOR_KEY_HEALTH_RETRY_DELAY_MS=50

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level threshold: 0 = info, 1 = warn, 2 = error
MEDOR_LOG_LEVEL=0

# Maximum depth of the async log queue before entries are dropped
MEDOR_LOG_QUEUE_DEPTH=65536

# Number of worker threads draining the async log queue
MEDOR_LOG_WORKERS=2

# Milliseconds between dropped-message summary entries
MEDOR_LOG_SUMMARY_INTERVAL_MS=5000
