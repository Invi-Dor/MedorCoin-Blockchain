# ── Docker and CI configuration ───────────────────────────────────────────────
# These are ignored by default in the original file but should be reviewed —
# docker-compose.yaml is often safe to commit for development environments.
# Remove these lines if you want Docker and CI files tracked.
docker-compose.yaml
.dockerignore
.gitlab-ci.yml

# ── Packaging artefacts ───────────────────────────────────────────────────────
*.bak
*.tar.gz
*.deb
*.rpm

# ── Protocol and wallet configuration ────────────────────────────────────────
