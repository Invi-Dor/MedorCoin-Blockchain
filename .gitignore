.config.json
secrets.json
credentials.json
api_key
apikey
*secret*
*password.txt
*token*

# ── Key rotation artefacts ────────────────────────────────────────────────────
# Backup directories created by rotate_admin_key.sh
.key_rotation_backup_*/

# ── RocksDB and LevelDB data directories ─────────────────────────────────────
