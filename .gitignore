# ── Node.js dependencies ──────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log

# ── Environment and secrets ───────────────────────────────────────────────────
# .env.example is intentionally NOT ignored — it is a safe template that
# should remain in version control.
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
*.cer
*.pub
*.p12
*.pfx
*.wallet
*.keystore
secret*.json
