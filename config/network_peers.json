  "discovery": {
    "enabled": true,
    "port": 30303,
    "maxPeers": 1000,
    "minPeers": 10,
    "targetOutboundPeers": 25,
    "targetInboundPeers": 50,
    "maxTrustedPeers": 100,
    "maxUntrustedPeers": 900,
    "dialTimeoutSecs": 10,
    "pingIntervalSecs": 30,
    "peerTimeoutSecs": 120,
    "handshakeTimeoutSecs": 15,
    "maxIdleTrustedSecs": 300,
    "maxIdleUntrustedSecs": 60,

    "retry": {
      "enabled": true,
      "maxAttempts": 5,
      "initialDelayMs": 1000,
      "maxDelayMs": 60000,
      "backoffMultiplier": 2.0
    },

    "natTraversal": {
      "enabled": true,
      "upnp": true,
      "stunServer": "stun.medorcoin.io:3478",
      "externalIp": "",
      "externalPort": 30303
    },

    "peerSelection": {
      "preferLowLatency": true,
      "maxLatencyMs": 500,
      "preferHighBandwidth": true,
      "minBandwidthMbps": 10,
      "diversifyRegions": true,
      "maxPeersPerRegion": 50,
      "maxPeersPerSubnet": 10,
      "maxPeersPerIP": 5
    },

    "dnsDiscovery": {
      "enabled": true,
      "refreshIntervalSecs": 300,
      "seeds": [
        "seed1.medorcoin.io",
        "seed2.medorcoin.io",
        "seed3.medorcoin.io",
        "seed4.medorcoin.io",
        "seed5.medorcoin.io"
      ]
    },

    "fallback": {
      "enabled": true,
      "strategy": "dns_then_hardcoded",
      "retryIntervalSecs": 60,
      "maxFallbackAttempts": 10
    }
  },

  "security": {
    "tls": {
      "enabled": true,
      "minVersion": "1.3",
      "requirePeerAuthentication": true,
      "requireSignedHandshake": true,
      "certPath": "",
      "keyPath": ""
    },
    "chainIdVerification": true,
    "networkVersionVerification": true,
    "maxConnectionsPerIP": 5,
    "ban": {
      "enabled": true,
      "defaultDurationSecs": 3600,
      "maxDurationSecs": 86400,
      "permanentBanThreshold": 10
    },
    "sybil": {
      "enabled": true,
      "maxPeersPerASN": 20,
      "maxPeersPerCountry": 100,
      "requireProofOfWork": false
    },
    "rateLimit": {
      "enabled": true,
      "maxMessagesPerSecond": 100,
      "maxBytesPerSecond": 10485760,
      "trustedMultiplier": 2,
      "maxNewConnectionsPerMinute": 60
    }
  },

  "peerPolicy": {
    "trusted": {
      "bypassRateLimit": true,
      "bypassBanCheck": false,
      "priorityQueuing": true,
      "keepAlive": true,
      "reconnectOnDisconnect": true,
      "maxIdleTimeSecs": 300
    },
    "untrusted": {
      "bypassRateLimit": false,
      "bypassBanCheck": false,
      "priorityQueuing": false,
      "keepAlive": false,
      "reconnectOnDisconnect": false,
      "maxIdleTimeSecs": 60,
      "requireHandshakeWithinSecs": 10
    },
    "eviction": {
      "strategy": "lowest_score",
      "scoreFactors": {
        "uptime": 0.3,
        "latency": 0.3,
        "bandwidth": 0.2,
        "blocksRelayed": 0.2
      }
    }
  },

  "protocol": {
    "version": 1,
    "minSupportedVersion": 1,
    "maxMessageSizeMB": 32,
    "handshakeTimeoutSecs": 15,
    "compression": {
      "enabled": true,
      "algorithm": "snappy"
    },
    "messageTypes": {
      "HELLO": 0,
      "DISCONNECT": 1,
      "PING": 2,
      "PONG": 3,
      "GET_PEERS": 4,
      "PEERS": 5,
      "NEW_BLOCK": 6,
      "GET_BLOCKS": 7,
      "BLOCKS": 8,
      "NEW_TX": 9,
      "GET_TXS": 10,
      "TXS": 11,
      "STATUS": 12,
      "GET_RECEIPTS": 13,
      "RECEIPTS": 14
    }
  },

  "persistence": {
    "enabled": true,
    "dbPath": "/var/lib/medorcoin/peers",
    "schemaVersion": 1,
    "saveOnShutdown": true,
    "loadOnStartup": true,
    "saveBans": true,
    "saveMetrics": true
  },

  "monitoring": {
    "enabled": true,
    "logConnections": true,
    "logDisconnections": true,
    "logBans": true,
    "metricsEnabled": true,
    "metricsPort": 9091,
    "healthCheckEnabled": true,
    "healthCheckPort": 9092,
    "alertOnMinPeersBreach": true,
    "minPeersAlertThreshold": 10,
    "broadcastThreads": 8
  },

  "reservedPeers": [
    "node1-us-east.medorcoin.io:30303",
    "node1-eu-west.medorcoin.io:30303",
    "node1-ap-southeast.medorcoin.io:30303",
    "node1-af-south.medorcoin.io:30303"
  ],

  "blacklist": [],
  "whitelist": []
}
